# ── SeineCrops · .gitignore ───────────────────────────────────────────────────

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Environnements virtuels ───────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── Secrets & configuration locale ───────────────────────────────────────────
.env.local
*.env
secrets.yml
secrets.yaml
credentials.json
# Clés d'accès CDSE / Sentinel Hub (ne jamais committer)
cdse_credentials.*
sentinelhub_config.*

# ── Données brutes (volumineuses, non redistribuées) ─────────────────────────
# Règle : exclure par type de fichier, PAS par dossier entier
# (ignorer un dossier entier neutralise les négations !... sur son contenu)
data/raw/**/*.7z
data/raw/**/*.zip
data/raw/**/*.pdf
data/raw/**/*.sql
data/raw/**/*.parquet
data/raw/s2/scl/
data/raw/**/*.png

# ── Formats raster ────────────────────────────────────────────────────────────
*.tif
*.tiff
*.jp2                         # Format natif Sentinel-2
*.nc                          # NetCDF (ERA5…)
*.h5
*.hdf5

# ── Formats vecteur ───────────────────────────────────────────────────────────
# GeoPackage : exclure sauf sentinel2_4tuiles_2154.gpkg (104 Ko, versionné)
data/raw/**/*.gpkg
data/vector/**/*.gpkg
!data/vector/s2_tiles/sentinel2_4tuiles_2154.gpkg

# Shapefiles (données intermédiaires non versionnées)
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.sbn
*.sbx
*.gpkg-shm
*.gpkg-wal

# Fichiers texte auxiliaires non versionnés
data/vector/**/*.txt

# ── QGIS ──────────────────────────────────────────────────────────────────────
*.qgz
*.qmd

# ── Cache de traitement ───────────────────────────────────────────────────────
cache/
.cache/
tmp/
temp/

# ── Modèles ML (artefacts lourds) ────────────────────────────────────────────
models/*.pkl
models/*.joblib
models/*.pt
models/*.pth
models/*.h5
# Exception : conserver les petits fichiers de métadonnées de modèle
!models/*.json
!models/*.yaml

# ── Notebooks — sorties et checkpoints ───────────────────────────────────────
util.ipynb
notebooks/.ipynb_checkpoints/
# Les notebooks eux-mêmes sont versionnés (sorties nettoyées avant commit)

# ── Tests & couverture ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Outils de qualité ────────────────────────────────────────────────────────
.ruff_cache/
.mypy_cache/

# ── IDE & éditeurs ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
